{
  "name": "benchpilot",
  "version": "0.0.0",
  "description": "Agent-first embedded device lifecycle toolkit.",
  "license": "MIT",
  "author": "RavelloH",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "benchpilot": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=22.13"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RavelloH/benchpilot.git"
  },
  "bugs": {
    "url": "https://github.com/RavelloH/benchpilot/issues"
  },
  "homepage": "https://github.com/RavelloH/benchpilot#readme",
  "keywords": [
    "embedded",
    "firmware",
    "automation",
    "device-management",
    "agent",
    "cli",
    "hardware",
    "microcontroller"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run i18n:generate && pnpm run adapter:validate && pnpm run clean && tsc -p tsconfig.json && pnpm run adapter:compile && pnpm run adapter:test",
    "dev": "node scripts/dev.mjs",
    "typecheck": "pnpm run i18n:generate && tsc -p tsconfig.json --noEmit",
    "i18n:generate": "node scripts/generate-i18n.mjs",
    "test": "pnpm run build && node scripts/compile-test-adapter.mjs && node --test test/*.test.js",
    "test:coverage": "pnpm run build && node --test --experimental-test-coverage test/*.test.js",
    "test:package": "pnpm run test:package:npm",
    "test:package:npm": "pnpm run build && node test/package-e2e.mjs",
    "adapter:validate": "node --import tsx src/adapters/compiler/cli.ts validate",
    "adapter:compile": "node --import tsx src/adapters/compiler/cli.ts compile",
    "adapter:test": "node --import tsx src/adapters/compiler/cli.ts test",
    "test:hardware:esp-idf": "pnpm run build && node test/hardware-esp-idf.mjs",
    "pack:check": "pnpm pack --dry-run",
    "format": "prettier --write . --log-level warn",
    "format:check": "prettier --check . --log-level warn",
    "prepare": "husky"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@inquirer/core": "^11.2.1",
    "@inquirer/prompts": "^8.5.2",
    "@inquirer/search": "^4.2.1",
    "@inquirer/select": "^5.2.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "rlog-js": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "yaml": "^2.9.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,yml,yaml,md}": "prettier --write --ignore-unknown"
  }
}
