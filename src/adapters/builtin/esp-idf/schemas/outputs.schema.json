{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "benchpilot://adapter/esp-idf/outputs",
  "type": "object",
  "$defs": {
    "empty": { "type": "object", "additionalProperties": false },
    "info": { "type": "object", "additionalProperties": true },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_name",
        "project_version",
        "target",
        "idf_version",
        "application_bin",
        "flash_size",
        "flash_file_count"
      ],
      "properties": {
        "project_name": { "type": "string" },
        "project_version": { "type": "string" },
        "target": { "type": "string" },
        "idf_version": { "type": "string" },
        "application_bin": { "type": "string" },
        "flash_size": { "type": "string" },
        "flash_file_count": { "type": "integer", "minimum": 0 }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available"],
      "properties": {
        "available": { "type": "boolean", "default": true },
        "flash_code_bytes": { "type": "integer", "minimum": 0 },
        "flash_data_bytes": { "type": "integer", "minimum": 0 },
        "ram_bytes": { "type": "integer", "minimum": 0 },
        "diram_bytes": { "type": "integer", "minimum": 0 },
        "dram_bytes": { "type": "integer", "minimum": 0 },
        "iram_bytes": { "type": "integer", "minimum": 0 },
        "image_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lines", "bytes", "marker", "truncated", "stop_reason"],
      "properties": {
        "lines": { "type": "integer", "minimum": 0 },
        "bytes": { "type": "integer", "minimum": 0 },
        "marker": { "type": "boolean" },
        "truncated": { "type": "boolean" },
        "stop_reason": {
          "enum": ["timeout", "marker", "max_lines", "max_bytes"]
        }
      }
    },
    "reset": { "type": "object", "additionalProperties": true },
    "deploy": { "type": "object", "additionalProperties": true }
  }
}
