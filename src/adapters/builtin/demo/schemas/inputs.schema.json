{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "benchpilot://adapter/demo/inputs",
  "type": "object",
  "$defs": {
    "empty": { "type": "object", "additionalProperties": false },
    "build": { "type": "object", "additionalProperties": false },
    "secret-inspect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token"],
      "properties": {
        "token": {
          "type": "string",
          "minLength": 1,
          "x-benchpilot-cli": {
            "flag": "--token",
            "aliases": ["-t"],
            "secret": true
          }
        }
      }
    }
  }
}
