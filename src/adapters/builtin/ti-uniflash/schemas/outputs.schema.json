{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "benchpilot://adapter/ti-uniflash/outputs",
  "type": "object",
  "$defs": {
    "empty": { "type": "object", "additionalProperties": false },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["availability", "connection", "target", "tooling"],
      "properties": {
        "availability": { "const": "ready" },
        "connection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["transport", "endpoint"],
          "properties": {
            "transport": { "const": "debug-server" },
            "endpoint": { "type": "string", "minLength": 1 }
          }
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["model", "revision"],
          "properties": {
            "model": { "type": "string", "minLength": 1 },
            "revision": { "type": "string", "minLength": 1 }
          }
        },
        "tooling": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dslite"],
          "properties": {
            "dslite": { "const": "DSLite" }
          }
        }
      }
    },
    "info": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "hardware", "tooling"],
      "properties": {
        "identity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["model", "revision", "hardware_id"],
          "properties": {
            "model": { "type": "string", "minLength": 1 },
            "revision": { "type": "string", "minLength": 1 },
            "hardware_id": { "type": "string", "minLength": 1 }
          }
        },
        "hardware": {
          "type": "object",
          "additionalProperties": false,
          "required": ["flash"],
          "properties": {
            "flash": {
              "type": "object",
              "additionalProperties": false,
              "required": ["manufacturer", "device", "size"],
              "properties": {
                "manufacturer": { "type": "string", "minLength": 1 },
                "device": { "type": "string", "minLength": 1 },
                "size": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "tooling": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dslite"],
          "properties": {
            "dslite": { "const": "DSLite" }
          }
        }
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lines", "bytes", "marker", "truncated", "stop_reason"],
      "properties": {
        "lines": { "type": "integer", "minimum": 0 },
        "bytes": { "type": "integer", "minimum": 0 },
        "marker": { "type": "boolean" },
        "truncated": { "type": "boolean" },
        "stop_reason": {
          "enum": ["timeout", "marker", "max_lines", "max_bytes"]
        }
      }
    },
    "session-run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "status", "runId", "startedAt"],
      "properties": {
        "sessionId": {
          "type": "string",
          "pattern": "^session-[a-zA-Z0-9_-]+$"
        },
        "status": { "const": "running" },
        "runId": { "type": "string", "minLength": 1 },
        "startedAt": { "type": "string", "format": "date-time" }
      }
    },
    "session-stop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "sessionId": {
          "type": "string",
          "pattern": "^session-[a-zA-Z0-9_-]+$"
        },
        "status": { "enum": ["stopped", "failed", "not-running"] },
        "stoppedAt": { "type": "string", "format": "date-time" }
      }
    },
    "session-logs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["records"],
      "properties": {
        "sessionId": {
          "type": "string",
          "pattern": "^session-[a-zA-Z0-9_-]+$"
        },
        "status": {
          "enum": [
            "creating",
            "starting",
            "running",
            "stopping",
            "stopped",
            "failed"
          ]
        },
        "cursor": { "type": "string", "pattern": "^1:[0-9]+$" },
        "records": {
          "type": "array",
          "maxItems": 10000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "generation",
              "sequence",
              "timestamp",
              "stream",
              "encodingState"
            ],
            "properties": {
              "generation": { "const": 1 },
              "sequence": { "type": "integer", "minimum": 1 },
              "timestamp": { "type": "string", "format": "date-time" },
              "stream": { "const": "serial" },
              "text": { "type": "string" },
              "base64": { "type": "string" },
              "encodingState": { "enum": ["complete", "replacement", "binary"] }
            },
            "anyOf": [{ "required": ["text"] }, { "required": ["base64"] }]
          }
        }
      }
    },
    "session-send": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sessionId",
        "status",
        "bytesWritten",
        "framing",
        "writtenAt"
      ],
      "properties": {
        "sessionId": {
          "type": "string",
          "pattern": "^session-[a-zA-Z0-9_-]+$"
        },
        "status": { "const": "written" },
        "bytesWritten": { "type": "integer", "minimum": 0 },
        "framing": { "enum": ["line", "raw"] },
        "writtenAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
