{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "benchpilot://adapter/ti-uniflash/inputs",
  "type": "object",
  "$defs": {
    "empty": { "type": "object", "additionalProperties": false },
    "flash": {
      "type": "object",
      "required": ["image"],
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1,
          "description": "Path to the prebuilt firmware image accepted by the configured target.",
          "x-benchpilot-cli": { "flag": "image" }
        },
        "verify": {
          "type": "boolean",
          "default": true,
          "description": "Ask DSLite to verify the programmed image.",
          "x-benchpilot-cli": { "flag": "verify" }
        },
        "run_after_flash": {
          "type": "boolean",
          "default": false,
          "description": "Run the target after successful flashing and verification.",
          "x-benchpilot-cli": { "flag": "run-after-flash" }
        }
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "duration_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 10
        },
        "baud": {
          "type": "integer",
          "minimum": 1200,
          "maximum": 2000000,
          "default": 115200
        },
        "max_lines": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2000,
          "default": 2000
        },
        "max_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576,
          "default": 262144
        },
        "timestamp": {
          "type": "boolean",
          "default": false
        },
        "marker": {
          "type": "string",
          "maxLength": 256,
          "default": "",
          "description": "Optional serial text that ends the capture when observed.",
          "x-benchpilot-cli": { "flag": "marker" }
        }
      }
    },
    "session-run": {
      "type": "object",
      "additionalProperties": false
    },
    "session-stop": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "session_id": {
          "type": "string",
          "pattern": "^session-[a-zA-Z0-9_-]+$",
          "x-benchpilot-cli": { "flag": "session-id" }
        }
      }
    },
    "session-console": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "session_id": {
          "type": "string",
          "pattern": "^session-[a-zA-Z0-9_-]+$",
          "x-benchpilot-cli": { "flag": "session-id" }
        }
      }
    },
    "session-logs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "session_id": {
          "type": "string",
          "pattern": "^session-[a-zA-Z0-9_-]+$",
          "x-benchpilot-cli": { "flag": "session-id" }
        },
        "tail": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000,
          "x-benchpilot-cli": { "flag": "tail" }
        },
        "cursor": {
          "type": "string",
          "pattern": "^1:[0-9]+$",
          "x-benchpilot-cli": { "flag": "cursor" }
        },
        "follow": {
          "type": "boolean",
          "x-benchpilot-cli": { "flag": "follow" }
        }
      }
    },
    "session-send": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id"],
      "properties": {
        "session_id": {
          "type": "string",
          "pattern": "^session-[a-zA-Z0-9_-]+$",
          "x-benchpilot-cli": { "flag": "session-id" }
        },
        "text": {
          "type": "string",
          "maxLength": 4096,
          "x-benchpilot-cli": { "flag": "text", "secret": true }
        },
        "hex": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]+$",
          "maxLength": 8192,
          "x-benchpilot-cli": { "flag": "hex", "secret": true }
        },
        "base64": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/]+={0,2}$",
          "maxLength": 5464,
          "x-benchpilot-cli": { "flag": "base64", "secret": true }
        },
        "framing": {
          "enum": ["line", "raw"],
          "x-benchpilot-cli": { "flag": "framing" }
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "required": ["text"],
              "not": {
                "anyOf": [{ "required": ["hex"] }, { "required": ["base64"] }]
              }
            },
            {
              "required": ["hex"],
              "not": {
                "anyOf": [{ "required": ["text"] }, { "required": ["base64"] }]
              }
            },
            {
              "required": ["base64"],
              "not": {
                "anyOf": [{ "required": ["text"] }, { "required": ["hex"] }]
              }
            }
          ]
        }
      ]
    }
  }
}
