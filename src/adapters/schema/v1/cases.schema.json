{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "schema_version", "cases"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "benchpilot.adapter.cases" },
    "schema_version": { "const": 1 },
    "cases": { "type": "array", "items": { "$ref": "#/$defs/case" } }
  },
  "$defs": {
    "base": {
      "type": "object",
      "required": ["id", "type", "platform", "target", "context", "expect"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "platform": { "enum": ["windows", "linux", "macos"] },
        "target": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "context": { "type": "object", "additionalProperties": true }
      }
    },
    "context": { "type": "object", "additionalProperties": true },
    "errorExpectation": {
      "type": "object",
      "required": ["kind", "retryable"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" }
      }
    },
    "workflowStepExpectation": {
      "type": "object",
      "required": ["id", "uses", "with", "continue_on_error"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "uses": {
          "type": "string",
          "pattern": "^action:[a-z][a-z0-9-]*$"
        },
        "with": { "type": "object", "additionalProperties": true },
        "continue_on_error": { "type": "boolean" }
      }
    },
    "artifactEntryExpectation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["id", "path", "required", "multiple"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
            "path": { "type": "string", "minLength": 1 },
            "required": { "type": "boolean" },
            "multiple": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["id", "glob", "required", "multiple"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
            "glob": { "type": "string", "minLength": 1 },
            "required": { "type": "boolean" },
            "multiple": { "type": "boolean" }
          }
        }
      ]
    },
    "case": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/base" },
            {
              "type": "object",
              "required": [
                "id",
                "type",
                "platform",
                "target",
                "context",
                "expect"
              ],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                "type": { "const": "render-action" },
                "platform": { "enum": ["windows", "linux", "macos"] },
                "target": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                "context": { "$ref": "#/$defs/context" },
                "expect": {
                  "type": "object",
                  "required": ["args"],
                  "additionalProperties": false,
                  "properties": {
                    "tool": { "type": "string" },
                    "cwd": {},
                    "args": { "type": "array" },
                    "environment": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/base" },
            {
              "type": "object",
              "required": [
                "id",
                "type",
                "platform",
                "target",
                "context",
                "expect"
              ],
              "anyOf": [
                { "required": ["stdout_fixture"] },
                { "required": ["stderr_fixture"] }
              ],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                "type": { "const": "parse-output" },
                "platform": { "enum": ["windows", "linux", "macos"] },
                "target": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                "context": { "$ref": "#/$defs/context" },
                "stdout_fixture": { "type": "string", "pattern": "^fixtures/" },
                "stderr_fixture": { "type": "string", "pattern": "^fixtures/" },
                "exit_code": { "type": "integer" },
                "expect": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "success": { "type": "boolean" },
                    "error": { "$ref": "#/$defs/errorExpectation" },
                    "result": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "progress": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["event", "data"],
                        "additionalProperties": false,
                        "properties": {
                          "event": { "type": "string", "minLength": 1 },
                          "data": {
                            "type": "object",
                            "additionalProperties": true
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/base" },
            {
              "type": "object",
              "required": [
                "id",
                "type",
                "platform",
                "target",
                "context",
                "expect"
              ],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                "type": { "const": "plan-workflow" },
                "platform": { "enum": ["windows", "linux", "macos"] },
                "target": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                "context": { "$ref": "#/$defs/context" },
                "expect": {
                  "type": "object",
                  "required": ["steps"],
                  "additionalProperties": false,
                  "properties": {
                    "steps": {
                      "type": "array",
                      "items": {
                        "oneOf": [
                          { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                          { "$ref": "#/$defs/workflowStepExpectation" }
                        ]
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/base" },
            {
              "type": "object",
              "required": [
                "id",
                "type",
                "platform",
                "target",
                "context",
                "expect"
              ],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                "type": { "const": "resolve-artifacts" },
                "platform": { "enum": ["windows", "linux", "macos"] },
                "target": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                "context": { "$ref": "#/$defs/context" },
                "expect": {
                  "type": "object",
                  "required": ["entries"],
                  "additionalProperties": false,
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": { "$ref": "#/$defs/artifactEntryExpectation" }
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  }
}
