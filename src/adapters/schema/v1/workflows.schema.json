{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "schema_version", "workflows"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "benchpilot.adapter.workflows" },
    "schema_version": { "const": 1 },
    "workflows": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/id" },
      "additionalProperties": { "$ref": "#/$defs/workflow" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "duration": { "type": "string", "pattern": "^[1-9][0-9]*(ms|s|m|h)$" },
    "message": {
      "type": "object",
      "required": ["key", "fallback"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
        "fallback": { "type": "string", "minLength": 1 }
      }
    },
    "condition": {
      "type": "object",
      "required": ["path", "operator"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!.*(__proto__|prototype|constructor|\\$\\{))[a-z][a-z0-9_]*(\\.[a-zA-Z][a-zA-Z0-9_]*)*$"
        },
        "operator": {
          "enum": [
            "exists",
            "not-exists",
            "equals",
            "not-equals",
            "in",
            "not-in",
            "truthy",
            "falsy"
          ]
        },
        "value": {}
      },
      "allOf": [
        {
          "if": {
            "properties": { "operator": { "enum": ["equals", "not-equals"] } }
          },
          "then": { "required": ["value"] }
        },
        {
          "if": { "properties": { "operator": { "enum": ["in", "not-in"] } } },
          "then": {
            "required": ["value"],
            "properties": { "value": { "type": "array" } }
          }
        },
        {
          "if": {
            "properties": {
              "operator": {
                "enum": ["exists", "not-exists", "truthy", "falsy"]
              }
            }
          },
          "then": { "not": { "required": ["value"] } }
        }
      ]
    },
    "step": {
      "type": "object",
      "required": ["id", "uses"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "uses": { "type": "string", "pattern": "^action:[a-z][a-z0-9-]*$" },
        "progress_id": { "$ref": "#/$defs/id" },
        "label": { "$ref": "#/$defs/message" },
        "with": { "type": "object" },
        "when": { "$ref": "#/$defs/condition" },
        "continue_on_error": { "type": "boolean" }
      }
    },
    "workflow": {
      "type": "object",
      "required": ["timeout", "stop_on_failure", "steps"],
      "additionalProperties": false,
      "properties": {
        "timeout": { "$ref": "#/$defs/duration" },
        "stop_on_failure": { "type": "boolean" },
        "output": { "$ref": "#/$defs/id" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        }
      }
    }
  }
}
