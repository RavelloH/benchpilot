{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "schema_version", "platform", "overrides"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "benchpilot.adapter.platform" },
    "schema_version": { "const": 1 },
    "platform": { "enum": ["windows", "linux", "macos"] },
    "overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tools": { "$ref": "#/$defs/ruleMap" },
        "discoveries": { "$ref": "#/$defs/ruleMap" },
        "environments": { "$ref": "#/$defs/ruleMap" },
        "devices": { "$ref": "#/$defs/devices" },
        "actions": { "$ref": "#/$defs/ruleMap" },
        "workflows": { "$ref": "#/$defs/ruleMap" },
        "sessions": { "$ref": "#/$defs/ruleMap" },
        "parsers": { "$ref": "#/$defs/ruleMap" },
        "artifacts": { "$ref": "#/$defs/ruleMap" }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "partialRule": {
      "type": "object",
      "additionalProperties": true
    },
    "ruleMap": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/id" },
      "additionalProperties": { "$ref": "#/$defs/partialRule" }
    },
    "devices": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "discovery": { "$ref": "#/$defs/partialRule" },
        "identity": { "$ref": "#/$defs/partialRule" },
        "connections": { "$ref": "#/$defs/ruleMap" },
        "probe": { "$ref": "#/$defs/partialRule" }
      }
    }
  }
}
