{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "schema_version", "discoveries"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "benchpilot.adapter.tool-discovery" },
    "schema_version": { "const": 1 },
    "discoveries": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/id" },
      "additionalProperties": { "$ref": "#/$defs/discovery" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "platforms": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "windows": { "type": "boolean" },
        "linux": { "type": "boolean" },
        "macos": { "type": "boolean" }
      }
    },
    "base": {
      "type": "object",
      "required": ["id", "type", "priority"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "priority": { "type": "integer" },
        "platforms": { "$ref": "#/$defs/platforms" }
      }
    },
    "config": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["id", "type", "priority", "key"],
          "additionalProperties": false,
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "config" },
            "priority": { "type": "integer" },
            "platforms": { "$ref": "#/$defs/platforms" },
            "key": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "configPath": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["id", "type", "priority", "key", "append"],
          "additionalProperties": false,
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "config-path" },
            "priority": { "type": "integer" },
            "platforms": { "$ref": "#/$defs/platforms" },
            "key": { "type": "string", "minLength": 1 },
            "append": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "environment": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["id", "type", "priority", "variable"],
          "additionalProperties": false,
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "environment" },
            "priority": { "type": "integer" },
            "platforms": { "$ref": "#/$defs/platforms" },
            "variable": {
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
            }
          }
        }
      ]
    },
    "environmentPath": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["id", "type", "priority", "variable", "append"],
          "additionalProperties": false,
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "environment-path" },
            "priority": { "type": "integer" },
            "platforms": { "$ref": "#/$defs/platforms" },
            "variable": {
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
            },
            "append": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "path": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["id", "type", "priority", "names"],
          "additionalProperties": false,
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "path" },
            "priority": { "type": "integer" },
            "platforms": { "$ref": "#/$defs/platforms" },
            "names": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "fixed": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["id", "type", "priority", "paths"],
          "additionalProperties": false,
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "fixed" },
            "priority": { "type": "integer" },
            "platforms": { "$ref": "#/$defs/platforms" },
            "paths": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "glob": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["id", "type", "priority", "patterns"],
          "additionalProperties": false,
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "glob" },
            "priority": { "type": "integer" },
            "platforms": { "$ref": "#/$defs/platforms" },
            "patterns": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "jsonPath": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": [
            "id",
            "type",
            "priority",
            "file",
            "collection",
            "path",
            "append"
          ],
          "additionalProperties": false,
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "type": { "const": "json-path" },
            "priority": { "type": "integer" },
            "platforms": { "$ref": "#/$defs/platforms" },
            "file": { "type": "string", "minLength": 1 },
            "collection": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 },
            "append": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "candidate": {
      "oneOf": [
        { "$ref": "#/$defs/config" },
        { "$ref": "#/$defs/configPath" },
        { "$ref": "#/$defs/environment" },
        { "$ref": "#/$defs/environmentPath" },
        { "$ref": "#/$defs/path" },
        { "$ref": "#/$defs/fixed" },
        { "$ref": "#/$defs/glob" },
        { "$ref": "#/$defs/jsonPath" }
      ]
    },
    "discovery": {
      "type": "object",
      "required": ["strategy", "candidates", "validation"],
      "additionalProperties": false,
      "properties": {
        "strategy": { "const": "first-valid" },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/candidate" }
        },
        "validation": {
          "type": "object",
          "required": ["path_type", "executable"],
          "additionalProperties": false,
          "properties": {
            "path_type": { "enum": ["file", "directory"] },
            "executable": { "type": "boolean" }
          }
        },
        "probe": {
          "type": "object",
          "required": ["args", "parser", "timeout"],
          "additionalProperties": false,
          "properties": {
            "args": { "type": "array", "items": { "type": "string" } },
            "parser": { "$ref": "#/$defs/id" },
            "timeout": {
              "type": "string",
              "pattern": "^[1-9][0-9]*(ms|s|m|h)$"
            }
          }
        }
      }
    }
  }
}
