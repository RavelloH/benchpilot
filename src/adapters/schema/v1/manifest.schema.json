{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema",
    "schema_version",
    "id",
    "display_name",
    "adapter_version",
    "description",
    "capability_catalog_version",
    "minimum_benchpilot_version",
    "status",
    "deprecated",
    "tags"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "benchpilot.adapter.manifest" },
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "display_name": { "type": "string" },
    "adapter_version": { "type": "string" },
    "vendor": { "type": "string" },
    "description": { "type": "string" },
    "capability_catalog_version": { "const": 1 },
    "minimum_benchpilot_version": { "type": "string" },
    "status": { "enum": ["experimental", "stable", "deprecated", "disabled"] },
    "deprecated": { "type": "boolean" },
    "deprecation_reason": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "homepage": { "type": "string" },
    "documentation": { "type": "string" },
    "license": { "type": "string" },
    "replacement": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
  }
}
