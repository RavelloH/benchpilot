{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "schema_version", "parsers"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "benchpilot.adapter.parsers" },
    "schema_version": { "const": 1 },
    "parsers": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/id" },
      "additionalProperties": { "$ref": "#/$defs/parser" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "source": { "enum": ["stdout", "stderr", "both"] },
    "cast": { "enum": ["string", "integer", "number", "boolean", "json"] },
    "extract": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "id",
            "source",
            "type",
            "pattern",
            "target",
            "group",
            "cast",
            "required"
          ],
          "additionalProperties": false,
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "source": { "$ref": "#/$defs/source" },
            "type": { "const": "regex" },
            "pattern": { "type": "string", "minLength": 1 },
            "target": { "type": "string", "minLength": 1 },
            "group": { "type": "string", "minLength": 1 },
            "cast": { "$ref": "#/$defs/cast" },
            "required": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": [
            "id",
            "source",
            "type",
            "pointer",
            "target",
            "cast",
            "required"
          ],
          "additionalProperties": false,
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "source": { "$ref": "#/$defs/source" },
            "type": { "const": "json-pointer" },
            "pointer": { "type": "string", "pattern": "^/" },
            "target": { "type": "string", "minLength": 1 },
            "cast": { "$ref": "#/$defs/cast" },
            "required": { "type": "boolean" }
          }
        }
      ]
    },
    "progress": {
      "type": "object",
      "required": ["id", "source", "pattern", "event", "fields"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "source": { "$ref": "#/$defs/source" },
        "pattern": { "type": "string", "minLength": 1 },
        "event": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" },
        "fields": {
          "type": "object",
          "propertyNames": { "pattern": "^[a-z][a-z0-9_]*$" },
          "additionalProperties": { "$ref": "#/$defs/cast" }
        }
      }
    },
    "error": {
      "type": "object",
      "required": [
        "id",
        "priority",
        "source",
        "pattern",
        "kind",
        "retryable",
        "recovery"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "priority": { "type": "integer" },
        "source": { "$ref": "#/$defs/source" },
        "pattern": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" },
        "recovery": { "type": "array", "items": { "type": "string" } }
      }
    },
    "parser": {
      "type": "object",
      "required": ["mode", "encoding", "strip_ansi", "success_exit_codes"],
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["line", "buffer", "json"] },
        "encoding": { "type": "string", "minLength": 1 },
        "strip_ansi": { "type": "boolean" },
        "success_exit_codes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer" }
        },
        "extract": { "type": "array", "items": { "$ref": "#/$defs/extract" } },
        "progress": {
          "type": "array",
          "items": { "$ref": "#/$defs/progress" }
        },
        "errors": { "type": "array", "items": { "$ref": "#/$defs/error" } }
      }
    }
  }
}
